# Application
APP_NAME=RSITradingBot
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rsi_trading
POSTGRES_USER=rsi_user
POSTGRES_PASSWORD=rsi_password
DATABASE_URL=postgresql+asyncpg://rsi_user:rsi_password@localhost:5432/rsi_trading

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=market_data
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Hyperliquid
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_NETWORK=mainnet

# RSI Strategy Parameters
RSI_PERIOD=14
RSI_REGIME_TIMEFRAME=4h
RSI_REGIME_BULLISH_THRESHOLD=55
RSI_REGIME_BEARISH_THRESHOLD=45
RSI_SIGNAL_TIMEFRAME=1h
RSI_SIGNAL_LONG_PULLBACK_LOW=40
RSI_SIGNAL_LONG_PULLBACK_HIGH=48
RSI_SIGNAL_LONG_RECLAIM=50
RSI_SIGNAL_SHORT_BOUNCE_LOW=52
RSI_SIGNAL_SHORT_BOUNCE_HIGH=60
RSI_SIGNAL_SHORT_LOSE=50
RSI_EXECUTION_TIMEFRAME=15m
RSI_EXIT_PARTIAL_R=1.5
RSI_EXIT_BREAKEVEN_R=1.0
RSI_EXIT_MAX_HOURS=36

# Risk Parameters
RISK_PER_TRADE_MIN=0.0025
RISK_PER_TRADE_MAX=0.0075
MAX_LEVERAGE=3
MAX_TOTAL_EXPOSURE_PCT=0.30
UNIVERSE=BTC,ETH,SOL

# z.ai Integration
ZAI_API_KEY=
ZAI_API_URL=https://api.z.ai/v1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
