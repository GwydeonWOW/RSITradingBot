# =============================================================================
# RSITradingBot - Environment Configuration
# Copy to .env and fill in your values
#
# Only infrastructure and venue-level settings go here.
# Per-user strategy/risk/API settings are configured via the UI (user_settings table).
# =============================================================================

# Application
APP_NAME=RSITradingBot
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rsi_trading
POSTGRES_USER=rsi_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://rsi_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/rsi_trading

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=market_data
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Security
SECRET_KEY=change-me-to-random-string
ENCRYPTION_KEY=change-me-to-32-byte-hex-string

# Hyperliquid (global venue URLs; per-user creds are stored encrypted per wallet)
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_NETWORK=mainnet

# z.ai (base URL only; API keys are per-user in user_settings)
ZAI_API_URL=https://api.z.ai/v1

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*
